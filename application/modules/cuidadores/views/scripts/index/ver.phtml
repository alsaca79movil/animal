<div id="perfil-cuidador">
    <div class="text-center text-gray-400 dark:text-slate-500 py-20">Cargando perfil...</div>
</div>

<script>
const slug = '<?= $this->slug ?>';

fetch('<?= $this->baseUrl('/api/index/cuidador') ?>?slug=' + slug)
    .then(r => r.json())
    .then(res => {
        if (res.status !== 'ok') {
            document.getElementById('perfil-cuidador').innerHTML =
                '<div class="text-center text-red-400 py-20">Cuidador no encontrado.</div>';
            return;
        }
        renderPerfil(res.data);
    })
    .catch(() => {
        document.getElementById('perfil-cuidador').innerHTML =
            '<div class="text-center text-red-400 py-20">Error cargando el perfil.</div>';
    });

function renderPerfil(c) {
    const cats = (c.categorias || []).map(cat =>
        `<span class="flex items-center gap-2 bg-gray-50 dark:bg-slate-700 border border-gray-200 dark:border-slate-600 rounded-xl px-4 py-2 text-sm text-gray-700 dark:text-slate-300">
            ${cat.icono} ${cat.nombre}
        </span>`
    ).join('');

    const stars = Math.round(c.rating || 0);
    const starsHtml = '★'.repeat(stars) + '☆'.repeat(5 - stars);

    document.getElementById('perfil-cuidador').innerHTML = `

        <!-- Volver -->
        <a href="javascript:history.back()"
           class="inline-flex items-center gap-2 text-violet-600 font-semibold text-sm mb-6 hover:underline">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" d="M15 19l-7-7 7-7"/>
            </svg>
            Volver
        </a>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">

            <!-- COLUMNA IZQUIERDA -->
            <div class="lg:col-span-2 space-y-8">

                <!-- Avatar + nombre -->
                <div class="flex items-center gap-6">
                    <div class="w-24 h-24 rounded-full bg-violet-100 dark:bg-violet-900 flex items-center justify-center text-4xl flex-shrink-0 overflow-hidden">
                        ${c.foto
                            ? `<img src="${c.foto}" class="w-full h-full object-cover">`
                            : '🐾'}
                    </div>
                    <div>
                        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">${c.nombre}</h1>
                        <p class="text-gray-500 dark:text-slate-400 mt-1">📍 ${c.ciudad}${c.departamento ? ', ' + c.departamento : ''}</p>
                        <div class="flex gap-2 flex-wrap mt-3">
                            ${c.superhost  ? '<span class="flex items-center gap-1 bg-violet-100 dark:bg-violet-900 text-violet-700 dark:text-violet-300 text-xs font-semibold px-3 py-1 rounded-full">⭐ Superhost</span>' : ''}
                            ${c.verificado ? '<span class="flex items-center gap-1 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 text-xs font-semibold px-3 py-1 rounded-full">✓ Verificado</span>' : ''}
                            ${c.tienepatio ? '<span class="flex items-center gap-1 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 text-xs font-semibold px-3 py-1 rounded-full">🏡 Tiene patio</span>' : ''}
                        </div>
                    </div>
                </div>

                <hr class="border-gray-100 dark:border-slate-700">

                <!-- Descripción -->
                <div>
                    <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-3">Sobre mí</h2>
                    <p class="text-gray-600 dark:text-slate-400 leading-relaxed">
                        ${c.descripcion || 'Este cuidador aún no ha agregado una descripción.'}
                    </p>
                </div>

                <hr class="border-gray-100 dark:border-slate-700">

                <!-- Categorías -->
                <div>
                    <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-3">Mascotas que acepta</h2>
                    <div class="flex gap-3 flex-wrap">
                        ${cats || '<span class="text-gray-400 text-sm">No especificado</span>'}
                    </div>
                </div>

                <hr class="border-gray-100 dark:border-slate-700">

                <!-- Lo que ofrece -->
                <div>
                    <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Lo que ofrece</h2>
                    <div class="grid grid-cols-2 gap-4">
                        ${c.tienepatio ? `
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-slate-700 flex items-center justify-center text-xl">🏡</div>
                            <span class="text-sm text-gray-700 dark:text-slate-300">Patio amplio</span>
                        </div>` : ''}
                        ${c.capacidad ? `
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-slate-700 flex items-center justify-center text-xl">🐾</div>
                            <span class="text-sm text-gray-700 dark:text-slate-300">Hasta ${c.capacidad} mascotas</span>
                        </div>` : ''}
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-slate-700 flex items-center justify-center text-xl">📸</div>
                            <span class="text-sm text-gray-700 dark:text-slate-300">Fotos diarias</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-xl bg-gray-100 dark:bg-slate-700 flex items-center justify-center text-xl">🚗</div>
                            <span class="text-sm text-gray-700 dark:text-slate-300">Recogida a domicilio</span>
                        </div>
                    </div>
                </div>

                <hr class="border-gray-100 dark:border-slate-700">

                <!-- Rating -->
                <div>
                    <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Calificaciones</h2>
                    <div class="flex items-center gap-4">
                        <span class="text-4xl font-bold text-gray-900 dark:text-white">${c.rating ?? '—'}</span>
                        <div>
                            <div class="text-violet-600 text-xl">${starsHtml}</div>
                            <div class="text-sm text-gray-500 dark:text-slate-400">${c.totalresenas ?? 0} reseñas</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- COLUMNA DERECHA — Tarjeta reserva -->
            <div class="lg:col-span-1">
                <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-2xl p-7 shadow-lg sticky top-24">
                    <div class="flex items-baseline gap-2 mb-6">
                        <span class="text-3xl font-bold text-gray-900 dark:text-white">
                            $${Number(c.precionoche || 0).toLocaleString('es-CO')}
                        </span>
                        <span class="text-gray-500 dark:text-slate-400 text-sm">COP / noche</span>
                    </div>

                    <div class="grid grid-cols-2 border border-gray-200 dark:border-slate-600 rounded-xl overflow-hidden mb-3">
                        <div class="px-4 py-3 border-r border-gray-200 dark:border-slate-600 cursor-pointer hover:bg-gray-50 dark:hover:bg-slate-700">
                            <span class="block text-xs font-bold text-gray-800 dark:text-slate-200">ENTRADA</span>
                            <span class="text-sm text-gray-400 dark:text-slate-500">Agregar fecha</span>
                        </div>
                        <div class="px-4 py-3 cursor-pointer hover:bg-gray-50 dark:hover:bg-slate-700">
                            <span class="block text-xs font-bold text-gray-800 dark:text-slate-200">SALIDA</span>
                            <span class="text-sm text-gray-400 dark:text-slate-500">Agregar fecha</span>
                        </div>
                    </div>

                    <button class="w-full bg-violet-600 hover:bg-violet-700 text-white font-bold py-4 rounded-xl transition-colors text-base mb-3">
                        Reservar ahora
                    </button>
                    <p class="text-center text-xs text-gray-400 dark:text-slate-500 mb-5">No se te cobrará nada aún</p>

                    <div class="space-y-3 border-t border-gray-100 dark:border-slate-700 pt-4">
                        <div class="flex justify-between text-sm text-gray-600 dark:text-slate-400">
                            <span>$${Number(c.precionoche || 0).toLocaleString('es-CO')} × noche</span>
                            <span>—</span>
                        </div>
                        ${c.preciodia ? `
                        <div class="flex justify-between text-sm text-gray-600 dark:text-slate-400">
                            <span>Precio por día</span>
                            <span>$${Number(c.preciodia).toLocaleString('es-CO')}</span>
                        </div>` : ''}
                    </div>
                </div>
            </div>

        </div>
    `;
}
</script>
