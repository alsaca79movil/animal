<!DOCTYPE html>
<html lang="es" class="">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mis mascotas · AnimalPet</title>
    <script>if (localStorage.getItem('tema') === 'oscuro') document.documentElement.classList.add('dark');</script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>tailwind.config = { darkMode: 'class' };</script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .fade { animation: fadeIn 0.2s ease; }
        @keyframes fadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:translateY(0); } }
    </style>
</head>
<body class="bg-white dark:bg-slate-900 min-h-screen">

<!-- TOP BAR -->
<header class="border-b border-gray-100 dark:border-slate-800 px-8 py-4 flex items-center justify-between sticky top-0 bg-white dark:bg-slate-900 z-10">
    <a href="<?= $this->baseUrl('/') ?>" class="flex items-center gap-2">
        <div class="w-7 h-7 bg-violet-600 rounded-lg flex items-center justify-center">
            <svg class="w-4 h-4 fill-white" viewBox="0 0 24 24"><path d="M4.5 11a2.5 2.5 0 100-5 2.5 2.5 0 000 5zm15 0a2.5 2.5 0 100-5 2.5 2.5 0 000 5zM12 10a3 3 0 100-6 3 3 0 000 6zM5 18.5c0-3.87 3.13-7 7-7s7 3.13 7 7v.5H5v-.5z"/></svg>
        </div>
        <span class="text-violet-600 font-bold text-lg">animalpet</span>
    </a>
    <h1 class="text-base font-bold text-gray-900 dark:text-white">Mis mascotas</h1>
    <a href="<?= $this->baseUrl('/mascota/nueva') ?>"
        class="flex items-center gap-2 bg-violet-600 hover:bg-violet-700 text-white text-sm font-bold px-4 py-2 rounded-xl transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        Agregar
    </a>
</header>

<!-- CONTENIDO -->
<main class="max-w-4xl mx-auto px-6 py-10">
    <div id="lista" class="fade"></div>
</main>

<!-- MODAL EDITAR -->
<div id="modal" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center px-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl w-full max-w-lg p-8 relative">
        <button onclick="cerrarModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-700 dark:hover:text-slate-200">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6">Editar mascota</h2>
        <input type="hidden" id="e-id">
        <div class="space-y-4">
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Nombre</label>
                <input id="e-nombre" type="text" class="w-full border-2 border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-violet-500">
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Raza</label>
                    <input id="e-raza" type="text" class="w-full border-2 border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-violet-500">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Especie</label>
                    <select id="e-categoria" class="w-full border-2 border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-violet-500">
                        <option value="">Selecciona...</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Edad (años)</label>
                    <input id="e-edad" type="number" step="0.5" class="w-full border-2 border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-violet-500">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Peso (kg)</label>
                    <input id="e-peso" type="number" step="0.1" class="w-full border-2 border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-violet-500">
                </div>
            </div>
            <div>
                <label class="block text-xs font-bold text-gray-400 uppercase tracking-wider mb-1">Descripción</label>
                <textarea id="e-desc" rows="2" class="w-full border-2 border-gray-200 dark:border-slate-600 dark:bg-slate-700 dark:text-white rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-violet-500 resize-none"></textarea>
            </div>
        </div>
        <div id="msg-edit" class="hidden text-sm mt-3"></div>
        <div class="flex gap-3 mt-6">
            <button onclick="cerrarModal()" class="flex-1 border-2 border-gray-200 dark:border-slate-600 text-gray-700 dark:text-slate-300 font-semibold py-3 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                Cancelar
            </button>
            <button onclick="guardarEdicion()" class="flex-1 bg-violet-600 hover:bg-violet-700 text-white font-bold py-3 rounded-xl transition-colors">
                Guardar cambios
            </button>
        </div>
    </div>
</div>

<!-- MODAL CONFIRMAR ELIMINAR -->
<div id="modal-delete" class="hidden fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center px-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl w-full max-w-sm p-8 text-center">
        <div class="w-14 h-14 bg-red-100 dark:bg-red-900 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">⚠️</div>
        <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-2">¿Eliminar mascota?</h2>
        <p class="text-sm text-gray-500 dark:text-slate-400 mb-6">Esta acción no se puede deshacer.</p>
        <input type="hidden" id="delete-id">
        <div class="flex gap-3">
            <button onclick="cerrarDelete()" class="flex-1 border-2 border-gray-200 dark:border-slate-600 text-gray-700 dark:text-slate-300 font-semibold py-3 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors">
                Cancelar
            </button>
            <button onclick="confirmarEliminar()" class="flex-1 bg-red-500 hover:bg-red-600 text-white font-bold py-3 rounded-xl transition-colors">
                Eliminar
            </button>
        </div>
    </div>
</div>

<script>
const BASE  = '<?= $this->baseUrl() ?>';
const token = localStorage.getItem('ap_token');
if (!token) window.location.href = BASE + '/login';

let categorias = [];

async function init() {
    const r   = await fetch(BASE + '/api/index/categorias');
    const res = await r.json();
    categorias = res.data || [];
    const sel = document.getElementById('e-categoria');
    categorias.forEach(c => {
        const o = document.createElement('option');
        o.value = c.id; o.textContent = c.icono + ' ' + c.nombre;
        sel.appendChild(o);
    });
    cargarMascotas();
}

async function cargarMascotas() {
    const r   = await fetch(BASE + '/api/index/mismascotas', { headers: { 'Authorization': 'Bearer ' + token } });
    const res = await r.json();
    const lista = document.getElementById('lista');

    if (!res.data?.length) {
        lista.innerHTML = `
            <div class="text-center py-20">
                <div class="text-6xl mb-4">🐾</div>
                <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Aún no tienes mascotas</h2>
                <p class="text-gray-500 dark:text-slate-400 mb-6">Agrega tu primera mascota para empezar a buscar cuidadores.</p>
                <a href="${BASE}/mascota/nueva" class="bg-violet-600 hover:bg-violet-700 text-white font-bold px-6 py-3 rounded-xl transition-colors inline-block">
                    Agregar mascota
                </a>
            </div>`;
        return;
    }

    lista.innerHTML = res.data.map(m => {
        const fotos = m.fotos || [];
        const fotoGrid = fotos.length === 0 ? `
            <div class="w-full h-56 bg-violet-50 dark:bg-violet-900 flex items-center justify-center text-5xl rounded-t-2xl">
                ${m.categoria_icono || '🐾'}
            </div>` :
        fotos.length === 1 ? `
            <div class="w-full h-56 rounded-t-2xl overflow-hidden">
                <img src="${fotos[0]}" class="w-full h-full object-cover">
            </div>` :
        fotos.length === 2 ? `
            <div class="grid grid-cols-2 gap-0.5 h-56 rounded-t-2xl overflow-hidden">
                <img src="${fotos[0]}" class="w-full h-full object-cover">
                <img src="${fotos[1]}" class="w-full h-full object-cover">
            </div>` :
        fotos.length === 3 ? `
            <div class="grid grid-cols-2 gap-0.5 h-56 rounded-t-2xl overflow-hidden">
                <img src="${fotos[0]}" class="w-full h-full object-cover row-span-2">
                <img src="${fotos[1]}" class="w-full h-full object-cover">
                <img src="${fotos[2]}" class="w-full h-full object-cover">
            </div>` : `
            <div class="grid grid-cols-2 gap-0.5 h-56 rounded-t-2xl overflow-hidden">
                <img src="${fotos[0]}" class="w-full h-full object-cover row-span-2">
                <img src="${fotos[1]}" class="w-full h-full object-cover">
                <div class="relative overflow-hidden">
                    <img src="${fotos[2]}" class="w-full h-full object-cover">
                    ${fotos.length > 3 ? `<div class="absolute inset-0 bg-black bg-opacity-40 flex items-center justify-center text-white font-bold text-lg">+${fotos.length - 3}</div>` : ''}
                </div>
            </div>`;

        return `
        <div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-2xl overflow-hidden">
            ${fotoGrid}
            <div class="p-5">
                <div class="flex items-start justify-between">
                    <div>
                        <h3 class="font-bold text-gray-900 dark:text-white text-lg">${m.nombre}</h3>
                        <p class="text-sm text-gray-500 dark:text-slate-400 mt-0.5">
                            ${m.categoria_icono || ''} ${m.categoria || ''}
                            ${m.raza ? ' · ' + m.raza : ''}
                            ${m.edad ? ' · ' + m.edad + ' años' : ''}
                            ${m.peso ? ' · ' + m.peso + ' kg' : ''}
                        </p>
                        ${m.descripcion ? `<p class="text-sm text-gray-500 dark:text-slate-400 mt-2 line-clamp-2">${m.descripcion}</p>` : ''}
                    </div>
                </div>
                <div class="flex gap-2 mt-4">
                    <button onclick="abrirEditar(${JSON.stringify(m).replace(/"/g, '&quot;')})"
                        class="flex-1 border border-gray-200 dark:border-slate-600 text-gray-700 dark:text-slate-300 text-sm font-semibold py-2.5 rounded-xl hover:bg-gray-50 dark:hover:bg-slate-700 transition-colors flex items-center justify-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                        Editar
                    </button>
                    <button onclick="abrirDelete(${m.id})"
                        class="border border-red-200 dark:border-red-800 text-red-500 text-sm font-semibold px-4 py-2.5 rounded-xl hover:bg-red-50 dark:hover:bg-red-950 transition-colors flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Eliminar
                    </button>
                </div>
            </div>
        </div>`;
    }).join('');
}

function abrirEditar(m) {
    document.getElementById('e-id').value        = m.id;
    document.getElementById('e-nombre').value    = m.nombre || '';
    document.getElementById('e-raza').value      = m.raza || '';
    document.getElementById('e-edad').value      = m.edad || '';
    document.getElementById('e-peso').value      = m.peso || '';
    document.getElementById('e-desc').value      = m.descripcion || '';
    document.getElementById('e-categoria').value = m.categoria_id || '';
    document.getElementById('msg-edit').classList.add('hidden');
    document.getElementById('modal').classList.remove('hidden');
}

function cerrarModal() { document.getElementById('modal').classList.add('hidden'); }

async function guardarEdicion() {
    const data = {
        id:          document.getElementById('e-id').value,
        nombre:      document.getElementById('e-nombre').value.trim(),
        raza:        document.getElementById('e-raza').value.trim(),
        edad:        document.getElementById('e-edad').value,
        peso:        document.getElementById('e-peso').value,
        descripcion: document.getElementById('e-desc').value.trim(),
        categoria_id:document.getElementById('e-categoria').value,
    };
    const r   = await fetch(BASE + '/api/index/editarmascota', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify(data)
    });
    const res = await r.json();
    if (res.status === 'ok') { cerrarModal(); cargarMascotas(); }
    else {
        const msg = document.getElementById('msg-edit');
        msg.textContent = res.message; msg.className = 'text-sm mt-3 text-red-500';
    }
}

function abrirDelete(id) {
    document.getElementById('delete-id').value = id;
    document.getElementById('modal-delete').classList.remove('hidden');
}

function cerrarDelete() { document.getElementById('modal-delete').classList.add('hidden'); }

async function confirmarEliminar() {
    const id  = document.getElementById('delete-id').value;
    const r   = await fetch(BASE + '/api/index/eliminarmascota', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ id })
    });
    const res = await r.json();
    if (res.status === 'ok') { cerrarDelete(); cargarMascotas(); }
}

init();
</script>
</body>
</html>
