async function cargarCategorias(seleccionadas) {
    const r   = await fetch(BASE + '/api/index/categorias');
    const res = await r.json();
    const grid = document.getElementById('cats-panel');
    if (!grid) return;

    const idsSeleccionados = seleccionadas.map(c => c.id);

    grid.innerHTML = (res.data || []).map(cat => `
        <div onclick="toggleCatPanel(this, ${cat.id})"
            class="cat-panel-item border-2 rounded-xl px-3 py-2 flex items-center gap-2 cursor-pointer transition-all text-sm font-medium
                   ${idsSeleccionados.includes(cat.id)
                     ? 'border-violet-600 bg-violet-50 dark:bg-violet-950 text-violet-700 dark:text-violet-300'
                     : 'border-gray-200 dark:border-slate-600 text-gray-700 dark:text-slate-300 hover:border-violet-400'}"
            data-id="${cat.id}">
            <span>${cat.icono}</span> ${cat.nombre}
        </div>
    `).join('');
}

function toggleCatPanel(el, id) {
    const sel = el.classList.contains('border-violet-600');
    el.className = `cat-panel-item border-2 rounded-xl px-3 py-2 flex items-center gap-2 cursor-pointer transition-all text-sm font-medium ${
        !sel ? 'border-violet-600 bg-violet-50 dark:bg-violet-950 text-violet-700 dark:text-violet-300'
             : 'border-gray-200 dark:border-slate-600 text-gray-700 dark:text-slate-300 hover:border-violet-400'
    }`;
    el.dataset.id = id;
}

function showTab(name, el) {
    ['perfil', 'cuidador', 'mascotas', 'cuenta'].forEach(t => {
        const tab = document.getElementById('tab-' + t);
        if (tab) tab.classList.add('hidden');
    });
    const target = document.getElementById('tab-' + name);
    if (target) target.classList.remove('hidden');
    document.querySelectorAll('.tab-btn').forEach(b => {
        b.classList.remove('border-violet-600', 'text-violet-600');
        b.classList.add('border-transparent', 'text-gray-500');
    });
    el.classList.add('border-violet-600', 'text-violet-600');
    el.classList.remove('border-transparent', 'text-gray-500');

    if (name === 'mascotas') {
        cargarCategoriasMascota();
        cargarMismascotas();
    }
}

async function guardarPerfil() {
    const data = {
        nombre:       document.getElementById('p-nombre').value.trim(),
        apellido:     document.getElementById('p-apellido').value.trim(),
        telefono:     document.getElementById('p-telefono').value.trim(),
        ciudad:       document.getElementById('p-ciudad').value.trim(),
        departamento: document.getElementById('p-departamento').value.trim(),
        tienemascota: document.getElementById('p-tienemascota').checked,
    };
    const r   = await fetch(BASE + '/api/index/actualizarperfil', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify(data)
    });
    const res = await r.json();
    const msg = document.getElementById('msg-perfil');
    msg.textContent = res.status === 'ok' ? '✓ Guardado correctamente' : res.message;
    msg.className   = res.status === 'ok' ? 'text-sm mt-3 text-green-600' : 'text-sm mt-3 text-red-500';
}

async function guardarCuidador() {
    const cats = Array.from(document.querySelectorAll('.cat-panel-item.border-violet-600'))
                      .map(el => parseInt(el.dataset.id));
    const data = {
        descripcion:       document.getElementById('c-descripcion').value.trim(),
        precionoche:       document.getElementById('c-precionoche').value,
        preciodia:         document.getElementById('c-preciodia').value,
        capacidadmascotas: document.getElementById('c-capacidad').value,
        direccion:         document.getElementById('c-direccion').value.trim(),
        latitud:           document.getElementById('c-latitud').value,
        longitud:          document.getElementById('c-longitud').value,
        tienepatio:        document.getElementById('c-tienepatio').checked,
        categorias:        cats,
    };
    const r   = await fetch(BASE + '/api/index/actualizarcuidador', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify(data)
    });
    const res = await r.json();
    const msg = document.getElementById('msg-cuidador');
    msg.textContent = res.status === 'ok' ? '✓ Guardado correctamente' : res.message;
    msg.className   = res.status === 'ok' ? 'text-sm mt-3 text-green-600' : 'text-sm mt-3 text-red-500';
}

async function cambiarPassword() {
    const actual    = document.getElementById('pass-actual').value;
    const nueva     = document.getElementById('pass-nueva').value;
    const confirmar = document.getElementById('pass-confirmar').value;
    const msg       = document.getElementById('msg-pass');
    if (nueva !== confirmar) {
        msg.textContent = 'Las contraseñas no coinciden';
        msg.className   = 'text-sm mt-3 text-red-500';
        return;
    }
    const r   = await fetch(BASE + '/api/index/cambiarpassword', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ password_actual: actual, password_nueva: nueva })
    });
    const res = await r.json();
    msg.textContent = res.status === 'ok' ? '✓ Contraseña actualizada' : res.message;
    msg.className   = res.status === 'ok' ? 'text-sm mt-3 text-green-600' : 'text-sm mt-3 text-red-500';
}

function cerrarSesion() {
    localStorage.removeItem('ap_token');
    localStorage.removeItem('ap_user');
    window.location.href = BASE + '/login';
}

async function cargarCategoriasMascota() {
    const r   = await fetch(BASE + '/api/index/categorias');
    const res = await r.json();
    const sel = document.getElementById('m-categoria');
    if (!sel || !res.data) return;
    res.data.forEach(c => {
        const opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.icono + ' ' + c.nombre;
        sel.appendChild(opt);
    });
}

// Almacén de blobs comprimidos
let fotosComprimidas = [];

function renderFotosGrid() {
    const grid = document.getElementById('m-fotos-grid');
    if (!grid) return;
    grid.innerHTML = '';
    fotosComprimidas.forEach((blob, i) => {
        const url = URL.createObjectURL(blob);
        const div = document.createElement('div');
        div.className = 'relative aspect-square rounded-xl overflow-hidden border border-gray-200 dark:border-slate-600';
        div.innerHTML = `
            <img src="${url}" class="w-full h-full object-cover">
            <button type="button" onclick="quitarFoto(${i})"
                class="absolute top-1 right-1 bg-black bg-opacity-50 text-white rounded-full w-5 h-5 flex items-center justify-center text-xs leading-none">✕</button>`;
        grid.appendChild(div);
    });
    // Botón agregar si hay menos de 5
    if (fotosComprimidas.length < 5) {
        const label = document.createElement('label');
        label.htmlFor = 'm-fotos';
        label.className = 'aspect-square rounded-xl border-2 border-dashed border-gray-300 dark:border-slate-600 flex flex-col items-center justify-center cursor-pointer hover:border-violet-500 transition-colors';
        label.innerHTML = `<svg class="w-6 h-6 text-gray-400 mb-1" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" d="M12 4.5v15m7.5-7.5h-15"/></svg><span class="text-xs text-gray-400 text-center">Agregar</span>`;
        grid.appendChild(label);
    }
}

function comprimirImagen(file) {
    return new Promise(resolve => {
        const reader = new FileReader();
        reader.onload = ev => {
            const img = new Image();
            img.onload = () => {
                const maxW   = 800;
                const canvas = document.createElement('canvas');
                let w = img.width, h = img.height;
                if (w > maxW) { h = Math.round(h * maxW / w); w = maxW; }
                canvas.width  = w;
                canvas.height = h;
                canvas.getContext('2d').drawImage(img, 0, 0, w, h);
                canvas.toBlob(blob => resolve(blob), 'image/jpeg', 0.8);
            };
            img.src = ev.target.result;
        };
        reader.readAsDataURL(file);
    });
}

document.addEventListener('change', async function(e) {
    if (e.target.id !== 'm-fotos') return;
    const nuevos = Array.from(e.target.files);
    for (const f of nuevos) {
        if (fotosComprimidas.length >= 5) break;
        const blob = await comprimirImagen(f);
        fotosComprimidas.push(blob);
    }
    e.target.value = ''; // reset input para poder añadir más
    renderFotosGrid();
});

function quitarFoto(idx) {
    fotosComprimidas.splice(idx, 1);
    renderFotosGrid();
}

async function guardarMascota() {
    const msg  = document.getElementById('msg-mascota');
    const form = new FormData();
    form.append('nombre',       document.getElementById('m-nombre').value.trim());
    form.append('raza',         document.getElementById('m-raza').value.trim());
    form.append('edad',         document.getElementById('m-edad').value);
    form.append('peso',         document.getElementById('m-peso').value);
    form.append('descripcion',  document.getElementById('m-descripcion').value.trim());
    form.append('categoria_id', document.getElementById('m-categoria').value);

    fotosComprimidas.forEach((blob, i) => form.append('fotos[]', blob, 'foto_' + i + '.jpg'));

    msg.textContent = 'Guardando...';
    msg.className   = 'text-sm mt-3 text-gray-400';

    const r   = await fetch(BASE + '/api/index/guardarmascota', {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token },
        body: form
    });
    const res = await r.json();
    msg.textContent = res.status === 'ok' ? '✓ Mascota guardada' : res.message;
    msg.className   = res.status === 'ok' ? 'text-sm mt-3 text-green-600' : 'text-sm mt-3 text-red-500';
    if (res.status === 'ok') {
        fotosComprimidas = [];
        renderFotosGrid();
        cargarMismascotas();
    }
}

async function cargarMismascotas() {
    const r   = await fetch(BASE + '/api/index/mismascotas', {
        headers: { 'Authorization': 'Bearer ' + token }
    });
    const res = await r.json();
    const lista = document.getElementById('lista-mascotas');
    if (!lista || !res.data?.length) return;
    lista.innerHTML = res.data.map(m => {
        const fotos = m.fotos || [];
        let fotosHtml = '';
        if (fotos.length) {
            const extras = fotos.slice(1,4).map(f =>
                '<div class="overflow-hidden"><img src="' + f + '" class="w-full h-full object-cover"></div>'
            ).join('');
            fotosHtml = '<div class="grid grid-cols-4 gap-1 h-40"><div class="col-span-2 row-span-2 overflow-hidden"><img src="' + fotos[0] + '" class="w-full h-full object-cover"></div>' + extras + '</div>';
        } else {
            fotosHtml = '<div class="h-24 bg-violet-50 dark:bg-violet-900 flex items-center justify-center text-4xl">' + (m.categoria_icono || '🐾') + '</div>';
        }
        return '<div class="bg-white dark:bg-slate-800 border border-gray-200 dark:border-slate-700 rounded-2xl overflow-hidden mb-4">' +
            fotosHtml +
            '<div class="p-4"><div class="font-semibold text-gray-900 dark:text-white">' + m.nombre + '</div>' +
            '<div class="text-sm text-gray-500 dark:text-slate-400 mt-0.5">' + (m.categoria_icono || '') + ' ' + (m.categoria || '') + ' · ' + (m.raza || 'Sin raza') + (m.edad ? ' · ' + m.edad + ' años' : '') + (m.peso ? ' · ' + m.peso + ' kg' : '') + '</div></div></div>';
    }).join('');
}

if (!token) {
    window.location.href = BASE + '/login';
} else {
    cargarPanel().then(() => {
        // Si viene con #mascotas abrir ese tab
        if (window.location.hash === '#mascotas') {
            const btn = document.querySelector("[onclick=\"showTab('mascotas', this)\"]");
            if (btn) btn.click();
        }
    });
}
</script>
