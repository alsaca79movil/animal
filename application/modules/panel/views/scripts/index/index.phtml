<div id="panel-container" class="max-w-3xl mx-auto py-8">
    <div class="text-center text-gray-400 dark:text-slate-500 py-20">Cargando panel...</div>
</div>

<script>
const BASE  = '<?= $this->baseUrl() ?>';
const token = localStorage.getItem('ap_token');

async function cargarPanel() {
    try {
        const r   = await fetch(BASE + '/api/index/mipanel', {
            headers: { 'Authorization': 'Bearer ' + token }
        });
        const res = await r.json();

        if (res.status !== 'ok') {
            localStorage.removeItem('ap_token');
            localStorage.removeItem('ap_user');
            window.location.href = BASE + '/login';
            return;
        }

        renderPanel(res.data);
        return true;

    } catch(e) {
        document.getElementById('panel-container').innerHTML =
            '<div class="text-center text-red-400 py-20">Error cargando el panel.</div>';
    }
}

