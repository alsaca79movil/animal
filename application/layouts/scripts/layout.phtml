    <script>
        const BASE_URL = '<?= $this->baseUrl() ?>';

        // Dark mode
        function toggleTema() {
            const esDark = document.documentElement.classList.toggle('dark');
            localStorage.setItem('tema', esDark ? 'oscuro' : 'claro');
            document.getElementById('icon-luna').classList.toggle('hidden', esDark);
            document.getElementById('icon-sol').classList.toggle('hidden', !esDark);
        }
        if (localStorage.getItem('tema') === 'oscuro') {
            document.getElementById('icon-luna').classList.add('hidden');
            document.getElementById('icon-sol').classList.remove('hidden');
        }

        // Menú dropdown
        function toggleMenu() {
            document.getElementById('nav-dropdown').classList.toggle('hidden');
        }

        // Cerrar menús al click fuera
        document.addEventListener('click', function(e) {
            const btnMenu = document.getElementById('btn-menu');
            const dropMenu = document.getElementById('nav-dropdown');
            if (!btnMenu.contains(e.target) && !dropMenu.contains(e.target)) {
                dropMenu.classList.add('hidden');
            }
            const dropEsp = document.getElementById('drop-especie');
            if (dropEsp && !e.target.closest('[onclick*="drop-especie"]') && !dropEsp.contains(e.target)) {
                dropEsp.classList.add('hidden');
            }
        });

        // Buscador
        let especieSeleccionada = null;

        function toggleSearchDrop(id) {
            document.getElementById(id).classList.toggle('hidden');
        }

        function seleccionarEspecie(id, label) {
            especieSeleccionada = id || null;
            document.getElementById('lbl-especie').textContent = label;
            document.getElementById('drop-especie').classList.add('hidden');
        }

        function buscarCuidadores() {
            const ciudad = document.getElementById('search-ciudad').value.trim();
            const desde  = document.getElementById('search-desde').value;
            const hasta  = document.getElementById('search-hasta').value;
            let url = BASE_URL + '/cuidadores/index/buscar?';
            if (especieSeleccionada) url += 'especie=' + especieSeleccionada + '&';
            if (ciudad) url += 'ciudad=' + encodeURIComponent(ciudad.toUpperCase()) + '&';
            if (desde)  url += 'desde=' + desde + '&';
            if (hasta)  url += 'hasta=' + hasta;
            window.location.href = url;
        }

        // Cargar categorías en dropdown del buscador
        fetch(BASE_URL + '/api/index/categorias')
            .then(r => r.json())
            .then(res => {
                const drop = document.getElementById('drop-especie');
                if (!drop || !res.data) return;
                drop.innerHTML =
                    `<div onclick="seleccionarEspecie(0, '🐾 Todas')"
                        class="px-4 py-2 text-sm cursor-pointer hover:bg-gray-50 dark:hover:bg-slate-700 text-gray-700 dark:text-slate-300">
                        🐾 Todas
                    </div>` +
                    res.data.map(c => `
                    <div onclick="seleccionarEspecie(${c.id}, '${c.icono} ${c.nombre}')"
                        class="px-4 py-2 text-sm cursor-pointer hover:bg-gray-50 dark:hover:bg-slate-700 text-gray-700 dark:text-slate-300">
                        ${c.icono} ${c.nombre}
                    </div>`).join('');
            });

        // Cerrar sesión desde navbar
        function cerrarSesionNav() {
            localStorage.removeItem('ap_token');
            localStorage.removeItem('ap_user');
            window.location.href = BASE_URL + '/login';
        }

        // Inicializar navbar según sesión JWT
        (function() {
            const token = localStorage.getItem('ap_token');
            const user  = localStorage.getItem('ap_user');
            if (token && user) {
                try {
                    const u = JSON.parse(user);
                    document.getElementById('menu-logueado').classList.remove('hidden');
                    document.getElementById('menu-noLogueado').classList.add('hidden');
                    document.getElementById('menu-nombre').textContent = u.nombre || 'Mi cuenta';
                    const avatar  = document.getElementById('nav-avatar');
                    const inicial = (u.nombre || 'U')[0].toUpperCase();
                    avatar.innerHTML = `<span class="text-white text-sm font-bold">${inicial}</span>`;
                    avatar.classList.remove('bg-slate-600');
                    avatar.classList.add('bg-violet-600');
                    document.getElementById('nav-publicar').classList.remove('hidden');
                    document.getElementById('nav-publicar').classList.add('block');
                } catch(e) {}
            }
        })();
    </script>

